# Example environment configuration.
#
# app.py reads these straight from the process environment. It does NOT
# auto-load this file. To use it locally:
#
#   set -a; . ./.env; set +a      # load into your shell, then run the app
#
# In production, prefer your process manager (systemd EnvironmentFile,
# Docker --env-file, etc.) over committing a real .env.

# Secret key used to sign Flask sessions. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If left unset, app.py generates a random key per process, so sessions
# (and anything signed with it) won't survive a restart.
SECRET_KEY=

# Enable Flask's debug server (auto-reload + interactive traceback).
# Accepts 1/true/yes. Leave it off (0) anywhere that isn't your laptop.
# Debug mode exposes an arbitrary-code-execution console.
FLASK_DEBUG=0

# Port the app binds to. Defaults to 5000 if unset.
PORT=5000

# Analytics dashboard is public at /stats (aggregate page-view counts only, no
# authentication). Optional analytics overrides:
# ANALYTICS_DB=/path/to/analytics.db         # default: ./analytics.db
# GEOIP_DB=/path/to/GeoLite2-Country.mmdb     # enables country-level stats

# ---- GTC Development contact form (/GTC/) ----------------------------------
# Enquiries are always stored in a local SQLite DB. To also have them emailed,
# set SMTP_HOST (and usually SMTP_USER/SMTP_PASSWORD). With SMTP_HOST unset,
# email is disabled and leads are stored only.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=app-password-here
# SMTP_STARTTLS=true
# CONTACT_TO=clarkegeorge0509@gmail.com       # where enquiries are sent
# CONTACT_FROM=                                # default: SMTP_USER (or CONTACT_TO)
# GTC_DB=/path/to/gtc.db                        # default: ./gtc.db
